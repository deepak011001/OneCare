{
  "name": "@onecare/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "node --import tsx --test src/**/*.test.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@onecare/auth": "workspace:*",
    "@onecare/cache": "workspace:*",
    "@onecare/config": "workspace:*",
    "@onecare/database": "workspace:*",
    "@onecare/events": "workspace:*",
    "@onecare/mcp": "workspace:*",
    "@onecare/ai": "workspace:*",
    "@onecare/security": "workspace:*",
    "@onecare/shared": "workspace:*",
    "@onecare/telemetry": "workspace:*",
    "@onecare/workflows": "workspace:*",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.2"
  }
}
