# OneCare — copy to .env and fill locally. Never commit real secrets.
NODE_ENV=development
AUTH_MODE=development

# Database
DATABASE_URL=postgresql://onecare:onecare@localhost:5432/onecare?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Web / Admin
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# MCP Gateway
MCP_GATEWAY_PORT=3003
MCP_GATEWAY_AUTH_TOKEN=change-me-local-only

# Auth / Session (SESSION_SECRET must be >= 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-32c
JWT_ISSUER=onecare
JWT_AUDIENCE=onecare-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200
SESSION_REMEMBER_ME_TTL_SECONDS=2592000
AUTH_COOKIE_NAME=oc_access
REFRESH_COOKIE_NAME=oc_refresh
CSRF_COOKIE_NAME=oc_csrf
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=120
AUTH_RATE_LIMIT_LIMIT=20

# Auth (Entra) — required when AUTH_MODE=entra
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:3001/v1/auth/callback
ENTRA_SCOPES=openid profile email offline_access

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# AI runtime (M3) — only mock executes in this milestone
AI_PROVIDER=mock
AI_DEFAULT_MODEL=mock-onecare-v1
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.2
AI_STREAM_CHUNK_DELAY_MS=8
AI_CONTEXT_MAX_CHARS=32000
AI_TOKEN_BUDGET=8192

# Conversations (M5.5) — memory keeps prior behavior; prisma enables persistence
CONVERSATION_STORE=memory
CONVERSATION_RETENTION_DAYS=365

# Enterprise Knowledge Platform (M6) — provider-agnostic; adapters swap via ports
KNOWLEDGE_ENGINE=platform
KNOWLEDGE_EMBEDDING_PROVIDER=local-hash
KNOWLEDGE_VECTOR_STORE=memory

# Connector defaults
CONNECTOR_DEFAULT_TIMEOUT_MS=15000
CONNECTOR_MAX_RETRIES=2

# Feature flags bootstrap (optional CSV of key=true|false)
FEATURE_FLAGS_BOOTSTRAP=

# Keka connector (optional — stub used when unset)
KEKA_API_BASE_URL=
KEKA_API_TOKEN=

# Web (M2)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_AUTH_MODE=development
