# OneCare — copy to .env and fill locally. Never commit real secrets.
NODE_ENV=development
AUTH_MODE=development

# Database
DATABASE_URL=postgresql://onecare:onecare@localhost:5432/onecare?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Web / Admin
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# MCP Gateway
MCP_GATEWAY_PORT=3003
MCP_GATEWAY_AUTH_TOKEN=change-me-local-only

# Auth / Session (SESSION_SECRET must be >= 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-32c
JWT_ISSUER=onecare
JWT_AUDIENCE=onecare-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200
SESSION_REMEMBER_ME_TTL_SECONDS=2592000
AUTH_COOKIE_NAME=oc_access
REFRESH_COOKIE_NAME=oc_refresh
CSRF_COOKIE_NAME=oc_csrf
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=120
AUTH_RATE_LIMIT_LIMIT=20

# Auth (Entra) — required when AUTH_MODE=entra
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:3001/v1/auth/callback
ENTRA_SCOPES=openid profile email offline_access

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
