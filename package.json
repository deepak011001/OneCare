{
  "name": "onecare",
  "private": true,
  "version": "0.0.0",
  "description": "OneCare — Enterprise Agentic AI Platform",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:migrate": "pnpm --filter @onecare/database prisma:migrate",
    "db:deploy": "pnpm --filter @onecare/database prisma:deploy",
    "db:seed": "pnpm --filter @onecare/database prisma:seed",
    "db:generate": "pnpm --filter @onecare/database prisma:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
